{
  "name": "resources-library-product",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "bunx --bun astro build && bunx --bun pagefind --site dist",
    "preview": "bunx --bun astro preview --host 127.0.0.1",
    "check": "bunx --bun astro check",
    "migrate:resources": "bun scripts/migrate-resources.ts",
    "new:resource": "bun scripts/new-resource.ts",
    "validate:content": "bun scripts/validate-content.ts",
    "check:links": "bun scripts/check-links.ts",
    "fetch:favicons": "bun scripts/fetch-favicons.ts",
    "generate:screenshots": "bun scripts/generate-screenshots.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.7.2",

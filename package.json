    "@heroui/styles": "3.0.4",
    "@inkjs/ui": "^2.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "astro": "^6.3.3",
    "fuse.js": "^7.3.0",
    "ink": "^7.0.3",
    "pagefind": "^1.5.2",
    "pinyin-pro": "^3.28.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-variants": "^3.0.0",
